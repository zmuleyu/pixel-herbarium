EXPO_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=xxx

# The following API keys are stored as Supabase Edge Function secrets (server-side only).
# Set them via Supabase Dashboard → Edge Functions → Secrets, or:
#   npx supabase secrets set PLANTNET_API_KEY=<key> REPLICATE_API_TOKEN=<token>
# Register at: https://my.plantnet.org/ (free, 500 identifications/day)
# PLANTNET_API_KEY=xxx        <- server-side only, NOT exposed to client
# REPLICATE_API_TOKEN=xxx     <- server-side only, NOT exposed to client
# REPLICATE_PIXEL_ART_MODEL=xxx  <- optional, defaults to zeke-xie/stable-diffusion-pixel-art

# Proxy bypass — prevents system HTTP_PROXY from routing localhost/Expo dev server through proxy
NO_PROXY=localhost,127.0.0.1,::1,0.0.0.0
no_proxy=localhost,127.0.0.1,::1,0.0.0.0
