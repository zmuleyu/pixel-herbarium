# === LOCAL DEVELOPMENT ===
EXPO_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=xxx
EXPO_PUBLIC_LINE_CHANNEL_ID=xxx   # LINE Login Channel ID from developers.line.biz

# === EAS BUILD ===
# EXPO_PUBLIC_SUPABASE_URL is set in eas.json (build.base.env)
# EXPO_PUBLIC_SUPABASE_ANON_KEY must be set as an EAS Secret:
#   eas secret:create --name EXPO_PUBLIC_SUPABASE_ANON_KEY --value <key> --scope project
# EXPO_PUBLIC_LINE_CHANNEL_ID must be set as an EAS Secret:
#   eas secret:create --name EXPO_PUBLIC_LINE_CHANNEL_ID --value <channel_id> --scope project

# === ANDROID NOTIFICATIONS (FCM) ===
# Place google-services.json in project root for push notifications.
# Download from Firebase Console > Project Settings > Your Apps > Android.
# This file is .gitignored and must be added manually.

# === SERVER-SIDE SECRETS ===
# The following API keys are stored as Supabase Edge Function secrets (server-side only).
# Set them via Supabase Dashboard → Edge Functions → Secrets, or:
#   npx supabase secrets set PLANTNET_API_KEY=<key> REPLICATE_API_TOKEN=<token>
# Register at: https://my.plantnet.org/ (free, 500 identifications/day)
# PLANTNET_API_KEY=xxx        <- server-side only, NOT exposed to client
# REPLICATE_API_TOKEN=xxx     <- server-side only, NOT exposed to client
# REPLICATE_PIXEL_ART_MODEL=xxx  <- optional, defaults to zeke-xie/stable-diffusion-pixel-art
# LINE_CHANNEL_SECRET=xxx     <- LINE Login Channel Secret (for auth-line edge function)
#   npx supabase secrets set LINE_CHANNEL_SECRET=<secret>

# Proxy bypass — prevents system HTTP_PROXY from routing localhost/Expo dev server through proxy
NO_PROXY=localhost,127.0.0.1,::1,0.0.0.0
no_proxy=localhost,127.0.0.1,::1,0.0.0.0
