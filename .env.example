EXPO_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=xxx

# The following API keys are stored as Supabase Edge Function secrets (server-side only).
# Set them via: npx supabase secrets set PLANTID_API_KEY=<key> REPLICATE_API_TOKEN=<token>
# PLANTID_API_KEY=xxx         <- server-side only, NOT exposed to client
# REPLICATE_API_TOKEN=xxx     <- server-side only, NOT exposed to client
# REPLICATE_PIXEL_ART_MODEL=xxx  <- optional, defaults to zeke-xie/stable-diffusion-pixel-art
