{
  "expo": {
    "name": "花図鉴",
    "slug": "pixel-herbarium",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "pixelherbarium",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f5f4f1"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.pixelherbarium.app",
      "usesAppleSignIn": true
    },
    "android": {
      "package": "com.pixelherbarium.app",
      "adaptiveIcon": {
        "backgroundColor": "#f5f4f1",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sharing",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "花図鉴では植物の撮影に使用します。"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "花図鉑では発見場所の記録に使用します。"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "花図鉑の開発テスト用にフォトライブラリへのアクセスを許可します。"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#ffffff",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
