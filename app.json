{
  "expo": {
    "name": "花図鉑",
    "slug": "pixel-herbarium",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "pixelherbarium",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f5f4f1"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.pixelherbarium.app",
      "buildNumber": "2",
      "usesAppleSignIn": true,
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": ["CA92.1"]
          }
        ],
        "NSPrivacyCollectedDataTypes": [],
        "NSPrivacyTracking": false
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "お花を撮影して識別するために、カメラを使用します。",
        "NSLocationWhenInUseUsageDescription": "お花を見つけた場所を記録するために、位置情報を使用します。",
        "NSPhotoLibraryUsageDescription": "お花の写真を選ぶために、フォトライブラリにアクセスします。",
        "LSApplicationQueriesSchemes": ["line"]
      }
    },
    "android": {
      "package": "com.pixelherbarium.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#f5f4f1",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sharing",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "お花を撮影して識別するために、カメラを使用します。"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "お花を見つけた場所を記録するために、位置情報を使用します。"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "お花の写真を選ぶために、フォトライブラリにアクセスします。"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#ffffff",
          "sounds": []
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "打卡カードを写真に保存するために、フォトライブラリにアクセスします。",
          "savePhotosPermission": "打卡カードを写真に保存するために、フォトライブラリにアクセスします。"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "updates": {
      "url": "https://u.expo.dev/74427c7e-dba6-4061-9cc9-3651d09fae01",
      "checkAutomatically": "NEVER"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "74427c7e-dba6-4061-9cc9-3651d09fae01"
      }
    },
    "owner": "cbnium"
  }
}
